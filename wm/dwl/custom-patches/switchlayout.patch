 void
+switchlayout(const Arg *arg)
+{
+    struct wlr_keyboard *kb = &kb_group->wlr_group->keyboard;
+    struct xkb_state *state = kb->xkb_state;
+    xkb_layout_index_t num_layouts = xkb_keymap_num_layouts(kb->keymap);
+    xkb_layout_index_t idx = arg->ui % num_layouts;
+    size_t num_names = sizeof(layout_names) / sizeof(layout_names[0]);
+    const char *name;
+    FILE *f;
+
+    xkb_state_update_mask(state,
+        xkb_state_serialize_mods(state, XKB_STATE_MODS_DEPRESSED),
+        xkb_state_serialize_mods(state, XKB_STATE_MODS_LATCHED),
+        xkb_state_serialize_mods(state, XKB_STATE_MODS_LOCKED),
+        0, 0, idx);
+
+    wlr_seat_keyboard_notify_modifiers(seat,
+        &kb->modifiers);
+
+    name = (idx < num_names) ? layout_names[idx] : "UNKNOWN";
+    f = fopen("/tmp/dwl-layout", "w");
+    if (f) {
+        fprintf(f, "%s", name);
+        fclose(f);
+    }
+}
