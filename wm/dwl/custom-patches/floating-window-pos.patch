From 9ad6313942c39d552364dd90b5668066f4270e1c Mon Sep 17 00:00:00 2001
From: mnlcz <mnlcz@tuta.io>
Date: Sat, 2 May 2026 12:04:20 -0300
Subject: [PATCH] Add x,y fields for floating window

---
 dwl.c | 10 ++++++++++
 1 file changed, 10 insertions(+)

diff --git a/dwl.c b/dwl.c
index 9af7dbf..e587d2b 100644
--- a/dwl.c
+++ b/dwl.c
@@ -237,6 +237,7 @@ typedef struct {
 	uint32_t tags;
 	int isfloating;
 	int monitor;
+	int x, y; /* initial position for floating windows, -1 to center */
 } Rule;
 
 typedef struct {
@@ -495,6 +496,15 @@ applyrules(Client *c)
 				if (r->monitor == i++)
 					mon = m;
 			}
+			if (c->isfloating) {
+				if (r->x == -1 && r->y == -1) {
+					c->geom.x = mon->w.x + (mon->w.width  - c->geom.width)  / 2;
+					c->geom.y = mon->w.y + (mon->w.height - c->geom.height) / 2;
+				} else if (r->x >= 0 && r->y >= 0) {
+					c->geom.x = mon->w.x + r->x;
+					c->geom.y = mon->w.y + r->y;
+				}
+			}
 		}
 	}
 	setmon(c, mon, newtags);
-- 
