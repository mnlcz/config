From e480a17d4d9a16526d90bb299f636a6ef0d5da94 Mon Sep 17 00:00:00 2001
From: mnlcz <mnlcz@tuta.io>
Date: Thu, 7 May 2026 19:41:27 -0300
Subject: [PATCH] Respect XCURSOR_THEME and XCURSOR_SIZE environment variables

---
 dwl.c | 8 ++++++--
 1 file changed, 6 insertions(+), 2 deletions(-)

diff --git a/dwl.c b/dwl.c
index e587d2b..797a66e 100644
--- a/dwl.c
+++ b/dwl.c
@@ -2620,8 +2620,12 @@ setup(void)
 	 * Xcursor themes to source cursor images from and makes sure that cursor
 	 * images are available at all scale factors on the screen (necessary for
 	 * HiDPI support). Scaled cursors will be loaded with each output. */
-	cursor_mgr = wlr_xcursor_manager_create(NULL, 24);
-	setenv("XCURSOR_SIZE", "24", 1);
+	const char *cursor_theme = getenv("XCURSOR_THEME");
+	const char *cursor_size_env = getenv("XCURSOR_SIZE");
+	unsigned int cursor_size = cursor_size_env ? (unsigned int)atoi(cursor_size_env) : 24;
+	cursor_mgr = wlr_xcursor_manager_create(cursor_theme, cursor_size);
+	setenv("XCURSOR_SIZE", cursor_size_env ? cursor_size_env : "24", 1);
+	setenv("XCURSOR_THEME", cursor_theme ? cursor_theme : "default", 1);
 
 	/*
 	 * wlr_cursor *only* displays an image on screen. It does not move around
-- 
2.47.3

