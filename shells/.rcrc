# Dirs
CONF=$home/Projects/config
PROJ=$home/Projects
SCRIPTS=$home/Projects/scripts
CSCRIPTS=$CONF/scripts
BSDSCRIPTS=$home/Projects/config/freebsd/bin
TEMPLATES=$CONF/templates
TODO=$home/Downloads/todo.txt
DWLCONF=$CONF/wm/dwl
PLAN9=/usr/local/plan9

# Dev
GOPATH=$PROJ/go
GOBIN=$GOPATH/bin

# PATH
path=($home/.local/bin $home/bin /usr/local/bin /usr/bin /bin /usr/local/sbin /usr/sbin /sbin /usr/local/plan9/bin $home/.cargo/bin $GOBIN)

# Default tools
EDITOR=vise
MANPAGER='less -R --use-color -Dd+r -Du+b'
BAT_THEME=GitHub

# Aliases
fn v        { vise $* }
fn bye      { tmux kill-server && exit }
fn ff       { fastfetch -c $CONF/tools/fastfetch/small.jsonc }
fn ga       { git add $* }
fn gb       { git branch $* }
fn gc       { git commit $* }
fn gco      { git checkout $* }
fn gd       { git diff $* }
fn gl       { git log --oneline --graph --decorate $* }
fn gp       { git push $* }
fn gpull    { git pull $* }
fn gs       { git status $* }
fn guile    { guile3 $* }
fn ll       { ls -laFoh $* }
fn pcf      { php-cs-fixer $* }
fn py       { python3.14 $* }

# Prompt
prompt=('% ' ' ')
