# Dirs
CONF=$home/Projects/config
PROJ=$home/Projects
SCRIPTS=$home/Projects/scripts
CSCRIPTS=$CONF/scripts
TEMPLATES=$CONF/templates
TODO=$home/Downloads/todo.txt

# Dev
GOPATH=$PROJ/go
GOBIN=$GOPATH/bin
GUIXHOME=$HOME/.config/guix/home-configuration.scm
GUIXSYS=/etc/config.scm
CHANNEL=$PROJ/guix-channel

# PATH
path=($path $GOBIN $home/.cargo/bin $home/.local/bin)

# Default tools
EDITOR=vim
MANPAGER='less -R --use-color -Dd+r -Du+b'
BAT_THEME=GitHub

# Aliases
fn e 	    { DISPLAY='' emacs $* & }
fn ff       { fastfetch -c $CONF/tools/fastfetch/small.jsonc }
fn ga       { git add $* }
fn gb       { git branch $* }
fn gc       { git commit $* }
fn gco      { git checkout $* }
fn gd       { git diff $* }
fn gl       { git log --oneline --graph --decorate $* }
fn gp       { git push $* }
fn gpull    { git pull $* }
fn gs       { git status $* }
fn ll       { ls -laFoh $* }
fn msview   { groff -ms -Tutf8 $* | less -R }
fn pcf      { php-cs-fixer $* }

# Prompt
prompt=('% ' ' ')
