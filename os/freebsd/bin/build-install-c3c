#/bin/sh

# Requires system installation of llvm (llvm19 tested)
# Requires CC and CXX redefinition for FreeBSD
cd /usr/local/src/c3c*
CC=/usr/local/bin/clang19 \
CXX=/usr/local/bin/clang++19 \
cmake -B build -S . \
    -DCMAKE_BUILD_TYPE=Release \
    -DC3_FETCH_LLVM=OFF \
    -DLLVM_DIR=/usr/local/llvm19/lib/cmake/llvm \
    -DLLVM_LINK_LLVM_DYLIB=ON

cmake --build build -j$(sysctl -n hw.ncpu)

# Install to /usr/local/{bin,lib}/c3 and /usr/local/share/man/man1/c3c.1
doas cmake --install build
