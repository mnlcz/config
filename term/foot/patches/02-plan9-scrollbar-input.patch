--- input.c.orig
+++ input.c
@@ -3244,6 +3244,46 @@ wl_pointer_button(void *data, struct wl_pointer *wl_pointer,
         break;
 
     case TERM_SURF_GRID: {
+        /* Scrollbar intercept */
+        if (term->conf->scrollback.indicator.position == SCROLLBACK_INDICATOR_POSITION_LEFT_BAR &&
+            term->conf->scrollback.bar.width > 0 &&
+            seat->mouse.x < (int)term->conf->scrollback.bar.width &&
+            state == WL_POINTER_BUTTON_STATE_PRESSED)
+        {
+            const int bar_height = term->rows * term->cell_height;
+            const int rel_y = seat->mouse.y - term->margins.top;
+            double frac = (double)rel_y / bar_height;
+            if (frac < 0.0) frac = 0.0;
+            if (frac > 1.0) frac = 1.0;
+
+            int amount = (int)(frac * term->rows);
+            if (amount < 1) amount = 1;
+
+            if (button == BTN_LEFT) {
+                cmd_scrollback_up(term, amount);
+            } else if (button == BTN_RIGHT) {
+                cmd_scrollback_down(term, amount);
+            } else if (button == BTN_MIDDLE) {
+                double pos_frac = (double)rel_y / bar_height;
+                if (pos_frac < 0.0) pos_frac = 0.0;
+                if (pos_frac > 1.0) pos_frac = 1.0;
+
+                int scrollback_start = term->grid->offset + term->rows;
+                int empty_rows = 0;
+                while (term->grid->rows[scrollback_start & (term->grid->num_rows - 1)] == NULL) {
+                    scrollback_start++;
+                    empty_rows++;
+                }
+                int populated_rows = term->grid->num_rows - empty_rows;
+                int target = (int)(pos_frac * (populated_rows - term->rows));
+                int new_view = (scrollback_start + target) & (term->grid->num_rows - 1);
+                term->grid->view = new_view;
+                term_damage_view(term);
+                render_refresh(term);
+            }
+            return;
+        }
+
         search_cancel(term);
         urls_reset(term);
 
